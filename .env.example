# Docker host config
HOST_PORT=8080

# Application config
PORT=8080
GITEA_URL=https://git.example.com
GITEA_TOKEN=your_token_here
WEBHOOK_SECRET=your_secret_here
# SSH key host path for Docker volume mount
SSH_KEY_HOST_PATH=~/.ssh/id_ed25519
# SSH key path inside container (don't change unless you modify docker-compose.yml)
SSH_KEY_PATH=/secrets/id_ed25519
CLAUDE_SKILL=pr-reviewer
CLONE_BASE_PATH=/data/reviews
RETENTION_HOURS=24
QUEUE_SIZE=100

# Claude CLI auth (choose one)
# Option 1: API key (pay-per-use)
# ANTHROPIC_API_KEY=sk-ant-...
# Option 2: Pro subscription (run `claude login` on host first)
CLAUDE_CONFIG_PATH=~/.claude
